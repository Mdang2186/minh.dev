{
    "name": "minh-dev-monorepo",
    "private": true,
    "packageManager": "npm@10.9.0",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "prisma:generate": "npm --workspace @minh-dev/database run db:generate",
        "prisma:push": "npm --workspace @minh-dev/database run db:push",
        "prisma:seed": "npm --workspace @minh-dev/database run db:seed",
        "clean": "turbo run clean"
    },
    "devDependencies": {
        "turbo": "latest"
    },
    "workspaces": [
        "apps/web",
        "apps/api",
        "packages/*"
    ]
}
