generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteProfile {
  id        String   @id @default(uuid())
  name      String
  name_vi   String?
  name_ja   String?
  name_fr   String?
  name_es   String?
  name_zh   String?
  name_ko   String?
  role      String
  role_vi   String?
  role_ja   String?
  role_fr   String?
  role_es   String?
  role_zh   String?
  role_ko   String?
  headline  String
  headline_vi String?
  headline_ja String?
  headline_fr String?
  headline_es String?
  headline_zh String?
  headline_ko String?
  intro     String
  intro_vi  String?
  intro_ja  String?
  intro_fr  String?
  intro_es  String?
  intro_zh  String?
  intro_ko  String?
  location  String?
  location_vi String?
  location_ja String?
  location_fr String?
  location_es String?
  location_zh String?
  location_ko String?
  email     String?
  phone     String?
  avatarUrl String?
  resumeUrl String?
  updatedAt DateTime @updatedAt
}

model Project {
  id            String             @id @default(uuid())
  title         String
  title_vi      String?
  title_ja      String?
  title_fr      String?
  title_es      String?
  title_zh      String?
  title_ko      String?
  slug          String             @unique
  summary       String
  summary_vi    String?
  summary_ja    String?
  summary_fr    String?
  summary_es    String?
  summary_zh    String?
  summary_ko    String?
  description   String?
  description_vi String?
  description_ja String?
  description_fr String?
  description_es String?
  description_zh String?
  description_ko String?
  content       String?
  content_vi    String?
  content_ja    String?
  content_fr    String?
  content_es    String?
  content_zh    String?
  content_ko    String?
  coverImage    String?
  githubUrl     String?
  demoUrl       String?
  role          String?
  role_vi       String?
  role_ja       String?
  role_fr       String?
  role_es       String?
  role_zh       String?
  role_ko       String?
  duration      String?
  teamSize      String?
  featured      Boolean            @default(false)
  published     Boolean            @default(true)
  sortOrder     Int                @default(0)
  directoryTree String?
  highlights    String[]           @default([])
  highlights_vi String[]           @default([])
  highlights_ja String[]           @default([])
  highlights_fr String[]           @default([])
  highlights_es String[]           @default([])
  highlights_zh String[]           @default([])
  highlights_ko String[]           @default([])
  languages     String[]           @default([])
  tools         String[]           @default([])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  images        ProjectImage[]
  techStacks    ProjectTechStack[]
}

model ProjectImage {
  id        String  @id @default(uuid())
  projectId String
  imageUrl  String
  altText   String?
  sortOrder Int     @default(0)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Post {
  id         String   @id @default(uuid())
  slug       String   @unique
  title      String
  excerpt    String?
  content    String
  published  Boolean  @default(false)
  coverImage String?
  tags       String[]
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TechStack {
  id       String             @id @default(uuid())
  name     String             @unique
  iconUrl  String?
  category String?
  projects ProjectTechStack[]
}

model ProjectTechStack {
  projectId   String
  techStackId String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  techStack   TechStack @relation(fields: [techStackId], references: [id], onDelete: Cascade)

  @@id([projectId, techStackId])
  @@index([techStackId])
}

model Experience {
  id        String   @id @default(uuid())
  title     String
  title_vi  String?
  title_ja  String?
  title_fr  String?
  title_es  String?
  title_zh  String?
  title_ko  String?
  org       String
  org_vi    String?
  org_ja    String?
  org_fr    String?
  org_es    String?
  org_zh    String?
  org_ko    String?
  time      String
  time_vi   String?
  time_ja   String?
  time_fr   String?
  time_es   String?
  time_zh   String?
  time_ko   String?
  details   String[] @default([])
  details_vi String[] @default([])
  details_ja String[] @default([])
  details_fr String[] @default([])
  details_es String[] @default([])
  details_zh String[] @default([])
  details_ko String[] @default([])
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SkillGroup {
  id        String  @id @default(uuid())
  title     String
  title_vi  String?
  title_ja  String?
  title_fr  String?
  title_es  String?
  title_zh  String?
  title_ko  String?
  sortOrder Int     @default(0)
  skills    Skill[]
}

model Skill {
  id        String     @id @default(uuid())
  groupId   String
  name      String
  name_vi   String?
  name_ja   String?
  name_fr   String?
  name_es   String?
  name_zh   String?
  name_ko   String?
  level     String?
  iconUrl   String?
  sortOrder Int        @default(0)
  group     SkillGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model SocialLink {
  id        String  @id @default(uuid())
  name      String
  url       String
  iconUrl   String?
  sortOrder Int     @default(0)
  visible   Boolean @default(true)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  message   String?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
}
